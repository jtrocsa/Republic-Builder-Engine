# Server-only — read via process.env.* inside api/*.js. Never prefix these with
# VITE_ or Vite will bundle them into the client-visible JS.
ANTHROPIC_API_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# Browser-safe — the only two Supabase values that may reach the client bundle.
# Protected by Postgres Row Level Security, not by secrecy.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
